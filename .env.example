# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# AI features use the Supabase Edge Function at supabase/functions/openai-chat.
# Set OPENAI_API_KEY as a Supabase function secret, not in the mobile app .env.

# Social direct automation
# Put real values in .env.social.local, not here.
SOCIAL_BRAND_INSTAGRAM_HANDLE=bodypilot.ai
SOCIAL_BRAND_TIKTOK_HANDLE=bodypilot.ai
INSTAGRAM_API_HOST=graph.instagram.com
META_GRAPH_VERSION=v24.0
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=
TIKTOK_ACCESS_TOKEN=
