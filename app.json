{
  "expo": {
    "name": "BodyPilot",
    "slug": "fitfusion",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": [
      "fitfusion",
      "exp+fitfusion"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dhairyagandhi.fitfusion",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "BodyPilot uses the camera to scan food barcodes and analyze meals",
        "NSLocationWhenInUseUsageDescription": "BodyPilot uses your location during cardio sessions to calculate distance, pace, and route data.",
        "NSPhotoLibraryUsageDescription": "BodyPilot needs photo access for progress photos and meal logging",
        "NSPhotoLibraryAddUsageDescription": "BodyPilot saves exported reports and progress images when you choose to share them."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F0F"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.fitfusion.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-image-picker",
      "expo-location",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icon.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5245b9ef-4ddf-48f6-86a2-4818cb6febb1"
      }
    }
  }
}
