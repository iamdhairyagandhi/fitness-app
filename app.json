{
  "expo": {
    "name": "FitFusion",
    "slug": "fitfusion",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "fitfusion",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fitfusion.app",
      "infoPlist": {
        "NSCameraUsageDescription": "FitFusion uses the camera to scan food barcodes and analyze meals",
        "NSPhotoLibraryUsageDescription": "FitFusion needs photo access for progress photos and meal logging"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F0F"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.fitfusion.app",
      "permissions": [
        "CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-image-picker",
      "expo-secure-store"
    ],
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icon.png"
    }
  }
}